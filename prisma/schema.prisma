generator client {
  provider = "prisma-client"
  output   = "../generated/prisma"
}
datasource db {
  provider = "postgresql"
}

model User {
  id        Int      @id @default(autoincrement())
  username  String   @unique
  password  String   // Hashed
  createdAt DateTime @default(now())
  media     Media[]
}

model Hero {
  id                String   @id @default("singleton")
  introBadge        String   @default("INTRO")
  videoDuration     String   @default("0:60")
  videoUrl          String   @default("https://www.youtube.com/watch?v=dQw4w9WgXcQ")
  title             String   @default("Meet John")
  description       String   @default("60 second intro")
  openToWork        Boolean  @default(true)
  location          String   @default("London, UK")
  sponsorshipInfo   String   @default("No sponsorship needed")
  resumeUrl         String   @default("#")
  updatedAt         DateTime @updatedAt
}

model Stat {
  id        Int      @id @default(autoincrement())
  value     String
  label     String
  order     Int      @default(0)
  updatedAt DateTime @updatedAt
}

model Experience {
  id          Int      @id @default(autoincrement())
  role        String
  company     String
  period      String
  description String
  skills      String   
  order       Int      @default(0)
  updatedAt   DateTime @updatedAt
}

model Project {
  id          Int      @id @default(autoincrement())
  title       String
  description String
  image       String
  tags        String   
  isFeatured  Boolean  @default(false)
  link        String?
  github      String?
  order       Int      @default(0)
  updatedAt   DateTime @updatedAt
}

model ContactMessage {
  id        Int      @id @default(autoincrement())
  name      String
  email     String
  message   String
  createdAt DateTime @default(now())
}

model Testimonial {
  id        Int      @id @default(autoincrement())
  name      String
  role      String
  content   String
  image     String?
  order     Int      @default(0)
  updatedAt DateTime @updatedAt
}

model Certification {
  id        Int      @id @default(autoincrement())
  title     String
  issuer    String
  date      String
  link      String?
  order     Int      @default(0)
  updatedAt DateTime @updatedAt
}

model Media {
  id           Int      @id @default(autoincrement())
  key          String   @unique // R2 object key (path in bucket)
  url          String   // Public URL to access the file
  originalName String   // User's original filename
  mimeType     String   // e.g. image/png, application/pdf
  size         Int      // Size in bytes
  width        Int?     // Optional: image width in px
  height       Int?     // Optional: image height in px
  folder       String   @default("general") // Logical folder for organization
  alt          String?  // Optional alt text for accessibility
  uploadedById Int?     // Optional: who uploaded it
  uploadedBy   User?    @relation(fields: [uploadedById], references: [id], onDelete: SetNull)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@index([folder])
  @@index([createdAt])
}

model Footer {
  id           String   @id @default("singleton")
  bio          String   @default("Full Stack Developer specializing in modern web technologies. Based in Silicon Valley, CA.")
  email        String   @default("hello@johndoe.com")
  linkedin     String   @default("#")
  github       String   @default("#")
  twitter      String   @default("#")
  availability String   @default("Open for Opportunities")
  updatedAt    DateTime @updatedAt
}
