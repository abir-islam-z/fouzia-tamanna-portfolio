generator client {
  provider = "prisma-client"
  output   = "../generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model User {
  id        Int      @id @default(autoincrement())
  username  String   @unique
  password  String
  createdAt DateTime @default(now())
  media     Media[]
}

model Hero {
  id              String   @id @default("singleton")
  introBadge      String   @default("OPEN TO WORK — SOC ANALYST")
  title           String   @default("Fouzia Tamanna")
  description     String   @default("Network Security & SOC Analyst specializing in threat detection, incident response, and systems security.")
  openToWork      Boolean  @default(true)
  location        String   @default("London, UK")
  sponsorshipInfo String   @default("No sponsorship needed")
  updatedAt       DateTime @updatedAt
  resumeUrl       String   @default("#")
  logoKey         String?
  logoUrl         String?
  subtitle        String   @default("MSc Computer Networks & Systems Security")
}

model Stat {
  id        Int      @id @default(autoincrement())
  value     String
  label     String
  order     Int      @default(0)
  updatedAt DateTime @updatedAt
}

model Experience {
  id          Int      @id @default(autoincrement())
  role        String
  company     String
  period      String
  description String
  skills      String
  order       Int      @default(0)
  updatedAt   DateTime @updatedAt
}

model Project {
  id          Int      @id @default(autoincrement())
  title       String
  description String
  image       String
  tags        String
  isFeatured  Boolean  @default(false)
  link        String?
  github      String?
  order       Int      @default(0)
  updatedAt   DateTime @updatedAt
}

model ContactMessage {
  id        Int      @id @default(autoincrement())
  name      String
  email     String
  message   String
  createdAt DateTime @default(now())
}

model Publication {
  id          Int      @id @default(autoincrement())
  title       String
  authors     String
  venue       String
  year        String
  abstract    String
  link        String?
  tags        String
  type        String   @default("journal")
  isPublished Boolean  @default(true)
  order       Int      @default(0)
  updatedAt   DateTime @updatedAt
}

model Testimonial {
  id        Int      @id @default(autoincrement())
  name      String
  role      String
  content   String
  image     String?
  order     Int      @default(0)
  updatedAt DateTime @updatedAt
}

model Certification {
  id        Int      @id @default(autoincrement())
  title     String
  issuer    String
  date      String
  link      String?
  order     Int      @default(0)
  updatedAt DateTime @updatedAt
}

model Media {
  id           Int      @id @default(autoincrement())
  key          String   @unique
  url          String
  originalName String
  mimeType     String
  size         Int
  width        Int?
  height       Int?
  folder       String   @default("general")
  alt          String?
  uploadedById Int?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
  uploadedBy   User?    @relation(fields: [uploadedById], references: [id])

  @@index([folder])
  @@index([createdAt])
}

model Footer {
  id           String   @id @default("singleton")
  bio          String   @default("Network Security & SOC Analyst focused on threat detection, incident response, and systems security. Based in London, UK.")
  email        String   @default("hello@example.com")
  linkedin     String   @default("#")
  github       String   @default("#")
  twitter      String   @default("#")
  availability String   @default("Open for SOC Analyst & Network Security Roles")
  updatedAt    DateTime @updatedAt
}
